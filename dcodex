#!/usr/bin/env bash

set -euo pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "error: dcodex must be run from inside this git repository" >&2
  exit 1
}

# shellcheck source=scripts/agent-common.sh
source "$PROJECT_ROOT/scripts/agent-common.sh"

launch_agent "codex" "$@"
